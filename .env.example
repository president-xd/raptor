# RAPTOR configuration
LLM_PROVIDER=nvidia
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
RAPTOR_ALLOW_EXTERNAL_LLM=false
LLM_MODEL=z-ai/glm-5.1
LLM_FALLBACK_MODEL=z-ai/glm-5.1
LLM_MAX_TOKENS=32768
LLM_TEMPERATURE=1
LLM_TOP_P=1
LLM_TIMEOUT_SECONDS=30
LLM_STREAM_RESPONSES=true
LLM_ENABLE_THINKING=true
LLM_CLEAR_THINKING=false

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change_me_neo4j_password

# Weaviate
WEAVIATE_URL=http://localhost:8080
WEAVIATE_GRPC_URL=localhost:50051
WEAVIATE_API_KEY=change_me_weaviate_api_key

# Elasticsearch / Redis
ELASTICSEARCH_URL=http://localhost:9200
ELASTIC_PASSWORD=change_me_elasticsearch_password
ELASTIC_INDEX_PREFIX=raptor-events
ELASTIC_POLL_ENABLED=false
ELASTIC_POLL_QUERY=*
ELASTIC_POLL_INTERVAL_SECONDS=300
ELASTIC_POLL_WINDOW_MINUTES=5
REDIS_URL=redis://localhost:6379
REDIS_CACHE_TTL_SECONDS=3600

# Threat feeds
CISA_KEV_URL=https://www.cisa.gov/sites/default/files/feeds/known_exploited_vulnerabilities.json

# API / frontend
RAPTOR_ENV=development
RAPTOR_PROCESS_ROLE=all
API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_PORT=3100
LOCAL_BIND_ADDRESS=127.0.0.1
RAPTOR_API_KEY=change_me_raptor_api_key
RAPTOR_AUTH_EXEMPT_HEALTH=true
RAPTOR_ALLOW_AUTH_DISABLED=false
RAPTOR_SESSION_COOKIE_SECURE=false
RAPTOR_REQUIRE_RBAC=true
RAPTOR_RATE_LIMIT_BACKEND=memory
RAPTOR_TRUSTED_SSO_ENABLED=false
RAPTOR_TRUSTED_PROXY_CIDRS=127.0.0.1/32,::1/128
RAPTOR_SSO_USER_HEADER=x-forwarded-user
RAPTOR_SSO_ROLES_HEADER=x-forwarded-roles
RAPTOR_SSO_TENANT_HEADER=x-forwarded-tenant
RAPTOR_BOOTSTRAP_ADMIN_USERNAME=admin
RAPTOR_BOOTSTRAP_ADMIN_PASSWORD=change_me_admin_password
RAPTOR_AUTH_MAX_FAILURES=5
RAPTOR_AUTH_LOCK_SECONDS=900
MAX_UPLOAD_BYTES=10485760
CORS_ALLOW_ORIGINS=http://localhost:3100,http://127.0.0.1:3100
CORS_ALLOW_CREDENTIALS=true
CSRF_TRUSTED_ORIGINS=http://localhost:3100,http://127.0.0.1:3100
RAPTOR_FRONTEND_ORIGIN=https://raptor.example.com
VITE_API_BASE_URL=/api/v1
RAPTOR_DB_ENGINE=sqlite
RAPTOR_DATABASE_URL=
RAPTOR_DB_PATH=./data/raptor.db
RAPTOR_ACKNOWLEDGE_SQLITE_LIMITS=false
EVIDENCE_ENCRYPTION_KEY=change_me_32_plus_char_evidence_key
EVIDENCE_RETENTION_DAYS=180
RAG_AUTO_INDEX=false
RAG_LOCAL_FALLBACK_ENABLED=true
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
RERANKER_MODEL=BAAI/bge-reranker-large
APT_REPORTS_DIR=./data/intel/apt_reports
RAPTOR_ALLOW_TEST_EMBEDDINGS=false
