# ============================================================
#  RAPTOR — Example Environment Configuration
#  Copy this file to .env and replace every change_me_* value
#  with cryptographically random secrets before any deployment.
#
#  Generate secrets:
#    openssl rand -hex 32                         # API key / passwords
#    python3 -c "import secrets,base64; \
#      print('base64:'+base64.b64encode(secrets.token_bytes(32)).decode())"
#                                                 # Evidence KEK (must be 32 bytes)
# ============================================================

# ── Runtime environment ───────────────────────────────────────────────────────
# development: relaxed auth, SQLite, in-memory rate limiting, /docs enabled
# production:  strict auth, HSTS, docs disabled, requires PostgreSQL + Redis
RAPTOR_ENV=development

# Which process to run inside the container:
#   all     → API + investigation worker in one process (dev only)
#   api     → API only (production web tier)
#   worker  → Background investigation worker only (production worker tier)
RAPTOR_PROCESS_ROLE=all

# ── API server ────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_PORT=3100
# Bind address for services that should not be exposed externally (Redis, ES, etc.)
LOCAL_BIND_ADDRESS=127.0.0.1

# ── Authentication ────────────────────────────────────────────────────────────
# Static API key for service-to-service calls and CI.
# Must be >= 32 characters in production.  Leave blank to disable API-key auth.
RAPTOR_API_KEY=change_me_raptor_api_key

# Skip authentication on GET /api/v1/health (safe for load-balancer probes)
RAPTOR_AUTH_EXEMPT_HEALTH=true

# Allow unauthenticated access from localhost when no API key is set.
# MUST be false in production.
RAPTOR_ALLOW_AUTH_DISABLED=false

# Set true in production (requires TLS termination upstream)
RAPTOR_SESSION_COOKIE_SECURE=false

# Enforce role-based access control on every endpoint
RAPTOR_REQUIRE_RBAC=true

# Rate-limit backend: memory (single-process) or redis (multi-process / prod)
RAPTOR_RATE_LIMIT_BACKEND=memory

# ── Session settings ──────────────────────────────────────────────────────────
# Session lifetime in seconds.  Default 28 800 = 8 hours.
# Reduce to 3600 or less for high-sensitivity environments.
RAPTOR_SESSION_TTL_SECONDS=28800

# ── Bootstrap admin account ───────────────────────────────────────────────────
# Created automatically on first startup if it doesn't already exist.
RAPTOR_BOOTSTRAP_ADMIN_USERNAME=admin
# REQUIRED: change before first deployment
RAPTOR_BOOTSTRAP_ADMIN_PASSWORD=change_me_admin_password

# After creating permanent admin accounts, set this to true and restart
# to permanently disable the bootstrap account.
RAPTOR_BOOTSTRAP_ADMIN_DISABLED=false

# Lockout policy: account locked after N failures for M seconds
RAPTOR_AUTH_MAX_FAILURES=5
RAPTOR_AUTH_LOCK_SECONDS=900

# ── SSO / trusted proxy headers ───────────────────────────────────────────────
# Enable when an upstream proxy (Authelia, OAuth2-Proxy, Nginx auth_request)
# injects identity headers after successful OIDC/SAML authentication.
RAPTOR_TRUSTED_SSO_ENABLED=false

# Comma-separated CIDRs of trusted proxy IPs (others are silently ignored)
RAPTOR_TRUSTED_PROXY_CIDRS=127.0.0.1/32,::1/128

# Header names injected by the proxy
RAPTOR_SSO_USER_HEADER=x-forwarded-user
# Values are comma-separated role names: analyst,viewer
RAPTOR_SSO_ROLES_HEADER=x-forwarded-roles
RAPTOR_SSO_TENANT_HEADER=x-forwarded-tenant

# ── CORS / CSRF ───────────────────────────────────────────────────────────────
# Comma-separated allowed browser origins.  In production: your exact frontend URL.
CORS_ALLOW_ORIGINS=http://localhost:3100,http://127.0.0.1:3100
CORS_ALLOW_CREDENTIALS=true

# Origins trusted for browser-session mutations (POST/PUT/PATCH/DELETE).
# Must match CORS_ALLOW_ORIGINS in production.
CSRF_TRUSTED_ORIGINS=http://localhost:3100,http://127.0.0.1:3100

# Public frontend URL used in outbound links / emails (not for CORS checks)
RAPTOR_FRONTEND_ORIGIN=https://raptor.example.com

# Vite proxy base path (leave as /api/v1 unless Nginx rewrites differently)
VITE_API_BASE_URL=/api/v1

# ── Upload limits ─────────────────────────────────────────────────────────────
# Maximum evidence upload size in bytes.  Default: 10 MiB.
MAX_UPLOAD_BYTES=10485760

# ── Database ──────────────────────────────────────────────────────────────────
# sqlite   → single-file, dev / testing only
# postgresql → required for production (multi-process safe)
RAPTOR_DB_ENGINE=sqlite

# Required when RAPTOR_DB_ENGINE=postgresql
# Format: postgresql://user:password@host:5432/dbname
RAPTOR_DATABASE_URL=

# SQLite file path (ignored when using PostgreSQL)
RAPTOR_DB_PATH=./data/raptor.db

# Set true only if you deliberately choose SQLite for a single-node production
# deployment and understand the concurrency limitations.
RAPTOR_ACKNOWLEDGE_SQLITE_LIMITS=false

# ── Evidence encryption ───────────────────────────────────────────────────────
# AES-256-GCM envelope encryption key (Key Encryption Key / KEK).
# Format: base64:<base64-encoded-32-bytes>  — generate with the command above.
# REQUIRED for production.  Files stored without encryption if left blank.
EVIDENCE_ENCRYPTION_KEY=change_me_32_plus_char_evidence_key

# Retention period for uploaded evidence files (days)
EVIDENCE_RETENTION_DAYS=180

# ── Evidence storage backend ──────────────────────────────────────────────────
# local → store on the container filesystem (requires a persistent volume)
# s3    → store in Amazon S3 (or compatible: MinIO, GCS, Backblaze)
RAPTOR_STORAGE_BACKEND=local

# Required when RAPTOR_STORAGE_BACKEND=s3
S3_BUCKET=
S3_PREFIX=evidence/
S3_REGION=us-east-1

# Override endpoint for MinIO / GCS / Backblaze (leave blank for AWS)
S3_ENDPOINT_URL=

# ── LLM / AI ─────────────────────────────────────────────────────────────────
# External LLM is disabled by default.  All prompts are scrubbed by
# llm_redactor.py before transmission when this is enabled.
RAPTOR_ALLOW_EXTERNAL_LLM=false

# Provider: nvidia (NVIDIA NIM) or openrouter
LLM_PROVIDER=nvidia

NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Primary model identifier (provider-specific)
LLM_MODEL=z-ai/glm-5.1
LLM_FALLBACK_MODEL=z-ai/glm-5.1

LLM_MAX_TOKENS=32768
LLM_TEMPERATURE=1
LLM_TOP_P=1
# Per-request timeout in seconds
LLM_TIMEOUT_SECONDS=30
LLM_STREAM_RESPONSES=true
LLM_ENABLE_THINKING=true
# Strip <thinking>…</thinking> blocks before returning to clients
LLM_CLEAR_THINKING=false

# ── RAG / Embeddings ──────────────────────────────────────────────────────────
# Automatically index MITRE ATT&CK + APT reports into Weaviate on startup
RAG_AUTO_INDEX=false
# Fall back to keyword search when Weaviate is unavailable
RAG_LOCAL_FALLBACK_ENABLED=true
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
RERANKER_MODEL=BAAI/bge-reranker-large
APT_REPORTS_DIR=./data/intel/apt_reports
# Allow placeholder embeddings in test suites (never set true in production)
RAPTOR_ALLOW_TEST_EMBEDDINGS=false

# ── Neo4j (attack graph) ──────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
# REQUIRED: replace before deployment
NEO4J_PASSWORD=change_me_neo4j_password

# ── Weaviate (vector RAG) ─────────────────────────────────────────────────────
WEAVIATE_URL=http://localhost:8080
WEAVIATE_GRPC_URL=localhost:50051
# REQUIRED: replace before deployment
WEAVIATE_API_KEY=change_me_weaviate_api_key

# ── Elasticsearch (log ingestion) ─────────────────────────────────────────────
ELASTICSEARCH_URL=http://localhost:9200
# REQUIRED: replace before deployment
ELASTIC_PASSWORD=change_me_elasticsearch_password
ELASTIC_INDEX_PREFIX=raptor-events

# Background Elasticsearch poller — disabled by default
ELASTIC_POLL_ENABLED=false
ELASTIC_POLL_QUERY=*
# How often the poller runs (seconds)
ELASTIC_POLL_INTERVAL_SECONDS=300
# How far back each poll reaches (minutes)
ELASTIC_POLL_WINDOW_MINUTES=5

# ── Redis (rate limiting + caching) ──────────────────────────────────────────
REDIS_URL=redis://localhost:6379
# TTL for cached threat-feed responses (seconds)
REDIS_CACHE_TTL_SECONDS=3600

# ── Threat intelligence feeds ─────────────────────────────────────────────────
CISA_KEV_URL=https://www.cisa.gov/sites/default/files/feeds/known_exploited_vulnerabilities.json
